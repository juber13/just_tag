# Server
PORT=3001
NODE_ENV=production

# MongoDB (use MONGODB_URI or username/password)
MONGODB_URI=
DB_NAME=justtag
DB_USERNAME=
PASSWORD=
# Optional: use if SRV DNS fails on your host (comma-separated)
MONGODB_DNS_SERVERS=8.8.8.8,1.1.1.1

# Cloudinary (image uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Razorpay (payments)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
